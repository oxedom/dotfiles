#!/usr/bin/env python3
"""Expose Claude Code resources to Codex without duplicating their contents."""

from __future__ import annotations

import argparse
import json
import os
import re
import sys
from dataclasses import dataclass, field
from pathlib import Path


GENERATED_MARKER = "# Generated by oxedom/dotfiles/sync-agent-resources."
VALID_SKILL_DIR = re.compile(r"^[a-z0-9][a-z0-9-]{0,63}$")


@dataclass
class Report:
    changed: list[str] = field(default_factory=list)
    current: list[str] = field(default_factory=list)
    warnings: list[str] = field(default_factory=list)
    drift: list[str] = field(default_factory=list)

    def change(self, message: str, check: bool) -> None:
        (self.drift if check else self.changed).append(message)


def parse_frontmatter(path: Path) -> tuple[dict[str, str], str]:
    text = path.read_text(encoding="utf-8")
    lines = text.splitlines()
    if not lines or lines[0].strip() != "---":
        return {}, text

    end = next(
        (index for index, line in enumerate(lines[1:], start=1) if line.strip() == "---"),
        None,
    )
    if end is None:
        return {}, text

    metadata: dict[str, str] = {}
    for line in lines[1:end]:
        match = re.match(r"^([A-Za-z][A-Za-z0-9_-]*):\s*(.*)$", line)
        if match:
            metadata[match.group(1)] = match.group(2).strip().strip("\"'")
    return metadata, "\n".join(lines[end + 1 :]).lstrip()


def normalized_skill_name(name: str) -> str:
    normalized = name.lower().replace("_", "-").replace(" ", "-")
    normalized = re.sub(r"[^a-z0-9-]+", "-", normalized)
    return re.sub(r"-+", "-", normalized).strip("-")[:64]


def normalized_agent_name(name: str) -> str:
    normalized = name.lower().replace("-", "_").replace(" ", "_")
    normalized = re.sub(r"[^a-z0-9_]+", "_", normalized)
    return re.sub(r"_+", "_", normalized).strip("_")


def same_target(link: Path, source: Path) -> bool:
    try:
        return link.resolve(strict=False) == source.resolve(strict=False)
    except OSError:
        return False


def ensure_symlink(
    source: Path,
    destination: Path,
    report: Report,
    check: bool,
    label: str,
) -> bool:
    if destination.is_symlink():
        if same_target(destination, source):
            report.current.append(f"{label}: {destination}")
            return True
        if not destination.exists():
            report.change(
                f"{label}: replace broken {destination} -> {source}", check
            )
            if not check:
                destination.unlink()
                relative_source = os.path.relpath(source, destination.parent)
                destination.symlink_to(
                    relative_source, target_is_directory=source.is_dir()
                )
            return True
        report.warnings.append(
            f"{label}: kept existing symlink {destination} -> {os.readlink(destination)}"
        )
        return False

    if destination.exists():
        report.current.append(f"{label}: kept existing {destination}")
        return False

    report.change(f"{label}: {destination} -> {source}", check)
    if not check:
        destination.parent.mkdir(parents=True, exist_ok=True)
        relative_source = os.path.relpath(source, destination.parent)
        destination.symlink_to(relative_source, target_is_directory=source.is_dir())
    return True


def write_generated(
    destination: Path,
    content: str,
    report: Report,
    check: bool,
    label: str,
) -> bool:
    if destination.exists() and not destination.is_file():
        report.warnings.append(f"{label}: kept non-file destination {destination}")
        return False

    if destination.exists():
        existing = destination.read_text(encoding="utf-8")
        if existing == content:
            report.current.append(f"{label}: {destination}")
            return True
        if GENERATED_MARKER not in existing[:500]:
            report.warnings.append(f"{label}: kept hand-written file {destination}")
            return False

    report.change(f"{label}: {destination}", check)
    if not check:
        destination.parent.mkdir(parents=True, exist_ok=True)
        destination.write_text(content, encoding="utf-8")
    return True


def remove_generated(
    destination: Path,
    report: Report,
    check: bool,
    label: str,
    remove_empty_parent: bool = False,
) -> None:
    report.change(f"{label}: remove stale {destination}", check)
    if check:
        return
    destination.unlink()
    if remove_empty_parent:
        try:
            destination.parent.rmdir()
        except OSError:
            pass


def discover_skill_names(root: Path) -> dict[str, Path]:
    discovered: dict[str, Path] = {}
    if not root.exists():
        return discovered

    for skill_file in root.glob("*/SKILL.md"):
        metadata, _ = parse_frontmatter(skill_file)
        name = normalized_skill_name(metadata.get("name", skill_file.parent.name))
        if name:
            discovered.setdefault(name, skill_file.parent)

    # Codex system skills are nested one level deeper under .system.
    for skill_file in root.glob(".system/*/SKILL.md"):
        metadata, _ = parse_frontmatter(skill_file)
        name = normalized_skill_name(metadata.get("name", skill_file.parent.name))
        if name:
            discovered.setdefault(name, skill_file.parent)
    return discovered


def expose_catalog_to_claude(
    catalog: Path,
    claude_home: Path,
    report: Report,
    check: bool,
) -> None:
    for category, pattern in (("skills", "*"), ("agents", "*.md"), ("commands", "*.md")):
        source_dir = catalog / category
        if not source_dir.exists():
            continue
        for source in sorted(source_dir.glob(pattern)):
            if category == "skills" and (
                not source.is_dir() or not (source / "SKILL.md").exists()
            ):
                continue
            if category == "skills" and not VALID_SKILL_DIR.fullmatch(source.name):
                report.warnings.append(
                    f"Claude skill: skipped non-portable directory name {source.name!r}"
                )
                continue
            ensure_symlink(
                source,
                claude_home / category / source.name,
                report,
                check,
                f"Claude {category[:-1]}",
            )


def sync_skills(
    source_root: Path,
    codex_skills: Path,
    codex_legacy_skills: Path | None,
    report: Report,
    check: bool,
    extra_sources: list[Path] | None = None,
) -> None:
    reserved = discover_skill_names(codex_skills)
    if codex_legacy_skills:
        for name, path in discover_skill_names(codex_legacy_skills).items():
            reserved.setdefault(name, path)

    sources = sorted(source_root.iterdir()) if source_root.exists() else []
    sources.extend(extra_sources or [])
    for source in sources:
        skill_file = source / "SKILL.md"
        if not source.is_dir() or not skill_file.exists():
            continue
        if not VALID_SKILL_DIR.fullmatch(source.name):
            report.warnings.append(
                f"skill: skipped non-portable directory name {source.name!r}"
            )
            continue

        metadata, _ = parse_frontmatter(skill_file)
        declared_name = normalized_skill_name(metadata.get("name", source.name))
        destination = codex_skills / source.name

        if destination.exists() or destination.is_symlink():
            ensure_symlink(source, destination, report, check, "Codex skill")
            reserved.setdefault(declared_name, destination)
            continue

        if declared_name in reserved:
            report.current.append(
                f"Codex skill: {declared_name} already provided by {reserved[declared_name]}"
            )
            continue

        if ensure_symlink(source, destination, report, check, "Codex skill"):
            reserved[declared_name] = destination

    source_root_resolved = source_root.resolve(strict=False)
    if codex_skills.exists():
        for destination in codex_skills.iterdir():
            if not destination.is_symlink() or destination.exists():
                continue
            target = (destination.parent / os.readlink(destination)).resolve(strict=False)
            if target.is_relative_to(source_root_resolved):
                report.change(f"Codex skill: remove stale {destination}", check)
                if not check:
                    destination.unlink()


def imported_skill_sources(instruction_file: Path, report: Report) -> list[Path]:
    if not instruction_file.exists():
        return []

    sources: list[Path] = []
    for line in instruction_file.read_text(encoding="utf-8").splitlines():
        if not line.startswith("@"):
            continue
        imported = Path(line[1:].strip()).expanduser()
        if imported.name != "SKILL.md":
            continue
        if imported.exists():
            sources.append(imported.parent)
        else:
            report.warnings.append(f"imported skill: missing {imported}")
    return sources


def command_wrapper(source: Path, destination: Path) -> tuple[str, str]:
    metadata, body = parse_frontmatter(source)
    name = normalized_skill_name(metadata.get("name", source.stem))
    description = metadata.get("description") or f"Run the shared Claude command {source.stem}."
    relative_source = os.path.relpath(source, destination.parent)
    content = f"""---
name: {name}
description: {description}
---

{GENERATED_MARKER}

Read and follow the authoritative shared command at
[`{source.name}`]({relative_source}).

Compatibility notes:

- Treat text following the skill mention as the command's arguments.
- If the source uses Claude's dynamic ``!`command``` syntax, run that command
  with the shell tool and use its output.
- Use Codex tools and subagents that are equivalent to any Claude-specific
  tool or `Task(...)` references.
"""
    if not body:
        content += "\nThe source file currently contains no command body.\n"
    return name, content


def sync_commands(
    source_root: Path,
    codex_skills: Path,
    report: Report,
    check: bool,
) -> None:
    expected: set[Path] = set()
    sources = (
        sorted(path for path in source_root.glob("*.md") if path.is_file())
        if source_root.exists()
        else []
    )
    for source in sources:
        name = normalized_skill_name(source.stem)
        if not name:
            report.warnings.append(f"command: skipped invalid name {source.name!r}")
            continue
        destination = codex_skills / name / "SKILL.md"
        expected.add(destination)
        _, content = command_wrapper(source, destination)
        write_generated(destination, content, report, check, "Codex command skill")

    if codex_skills.exists():
        for destination in codex_skills.glob("*/SKILL.md"):
            if destination in expected or not destination.is_file():
                continue
            if GENERATED_MARKER in destination.read_text(encoding="utf-8")[:500]:
                remove_generated(
                    destination,
                    report,
                    check,
                    "Codex command skill",
                    remove_empty_parent=True,
                )


def agent_adapter(source: Path) -> tuple[str, str]:
    metadata, _ = parse_frontmatter(source)
    source_name = metadata.get("name", source.stem)
    name = normalized_agent_name(source_name)
    description = metadata.get("description") or f"Shared agent adapted from {source.name}."
    tools = metadata.get("tools", "")
    permission_mode = metadata.get("permissionMode", "")
    read_only = permission_mode == "plan" or not re.search(
        r"\b(Write|Edit|Replace|NotebookEdit)\b", tools
    )

    compatibility = (
        f"Before doing any work, read and follow the authoritative shared agent "
        f"definition at {source}. "
        "Translate Claude-specific tool names to the closest Codex tools. "
        "Treat @path references as file paths, and use Codex subagents in place "
        "of Claude Task(...) calls. Claude model names, colors, tool allowlists, "
        "and permission metadata are descriptive only; the parent Codex session "
        "controls actual model, tools, sandboxing, and approvals."
    )

    lines = [
        GENERATED_MARKER,
        f"# Source: {source}",
        f"name = {json.dumps(name, ensure_ascii=False)}",
        f"description = {json.dumps(description, ensure_ascii=False)}",
        f"developer_instructions = {json.dumps(compatibility, ensure_ascii=False)}",
    ]
    if read_only:
        lines.append('sandbox_mode = "read-only"')
    return name, "\n".join(lines) + "\n"


def sync_agents(
    source_root: Path,
    codex_agents: Path,
    report: Report,
    check: bool,
) -> None:
    expected: set[Path] = set()
    sources = (
        sorted(path for path in source_root.glob("*.md") if path.is_file())
        if source_root.exists()
        else []
    )
    for source in sources:
        name, content = agent_adapter(source)
        if not name:
            report.warnings.append(f"agent: skipped invalid name {source.name!r}")
            continue
        destination = codex_agents / f"{name}.toml"
        expected.add(destination)
        write_generated(
            destination,
            content,
            report,
            check,
            "Codex agent",
        )

    if codex_agents.exists():
        for destination in codex_agents.glob("*.toml"):
            if destination in expected or not destination.is_file():
                continue
            if destination.read_text(encoding="utf-8").startswith(GENERATED_MARKER):
                remove_generated(destination, report, check, "Codex agent")


def sync_project_instruction(
    project: Path,
    report: Report,
    check: bool,
) -> None:
    claude_file = project / "CLAUDE.md"
    agents_file = project / "AGENTS.md"
    if claude_file.exists():
        ensure_symlink(
            claude_file,
            agents_file,
            report,
            check,
            "shared project instructions",
        )


def print_report(report: Report, check: bool) -> None:
    heading = "Would change" if check else "Changed"
    if report.changed or report.drift:
        print(f"\n{heading}:")
        for item in report.drift if check else report.changed:
            print(f"  + {item}")
    if report.warnings:
        print("\nPreserved / needs review:")
        for item in report.warnings:
            print(f"  ! {item}")
    print(
        f"\nSummary: {len(report.drift if check else report.changed)} "
        f"{'changes needed' if check else 'changed'}, "
        f"{len(report.current)} already available, "
        f"{len(report.warnings)} preserved warnings."
    )


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Expose Claude skills, commands, agents, and instructions to Codex."
    )
    scope = parser.add_mutually_exclusive_group()
    scope.add_argument(
        "--global",
        dest="global_scope",
        action="store_true",
        help="sync the dotfiles catalog and ~/.claude into user-level Codex config",
    )
    scope.add_argument(
        "--project",
        type=Path,
        help="sync one project's .claude resources into native Codex paths",
    )
    parser.add_argument(
        "--check",
        action="store_true",
        help="report missing or stale adapters without changing files",
    )
    args = parser.parse_args()

    report = Report()
    dotfiles_root = Path(__file__).resolve().parent
    home = Path.home()

    if args.project:
        project = args.project.expanduser().resolve()
        sync_skills(
            project / ".claude" / "skills",
            project / ".agents" / "skills",
            None,
            report,
            args.check,
        )
        sync_commands(
            project / ".claude" / "commands",
            project / ".agents" / "skills",
            report,
            args.check,
        )
        sync_agents(
            project / ".claude" / "agents",
            project / ".codex" / "agents",
            report,
            args.check,
        )
        sync_project_instruction(project, report, args.check)
    else:
        claude_home = home / ".claude"
        expose_catalog_to_claude(dotfiles_root, claude_home, report, args.check)
        expose_catalog_to_claude(
            dotfiles_root / "claude-global", claude_home, report, args.check
        )
        sync_skills(
            claude_home / "skills",
            home / ".agents" / "skills",
            home / ".codex" / "skills",
            report,
            args.check,
            extra_sources=imported_skill_sources(
                claude_home / "CLAUDE.md", report
            ),
        )
        sync_commands(
            claude_home / "commands",
            home / ".agents" / "skills",
            report,
            args.check,
        )
        sync_agents(
            claude_home / "agents",
            home / ".codex" / "agents",
            report,
            args.check,
        )

    print_report(report, args.check)
    return 1 if args.check and report.drift else 0


if __name__ == "__main__":
    sys.exit(main())
