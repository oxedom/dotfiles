{
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/tmux-merge-sessions.sh",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/claude-tab-state.sh working",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f ~/.claude/sounds/finish.mp3 ]; then cvlc --play-and-exit --quiet ~/.claude/sounds/finish.mp3 2>/dev/null || true; else paplay /usr/share/sounds/sound-icons/piano-3.wav 2>/dev/null || true; fi",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/claude-tab-state.sh done",
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/claude-tab-state.sh reset",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {},
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    }
  },
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "verbose": true,
  "preferredNotifChannel": "iterm2",
  "autoCompactEnabled": false,
  "agentPushNotifEnabled": true,
  "voiceEnabled": true
}
